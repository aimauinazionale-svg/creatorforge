# CreatorForge environment variables

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (optional — enables auth, persistence; cookie fallback works without it)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API (channel stats, videos, comments)
YOUTUBE_API_KEY=

# Google OAuth (optional — for YouTube OAuth flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/auth/youtube/callback

# Groq AI (required for AI features)
GROQ_API_KEY=

# Resend email (optional — emails log as skipped without key)
RESEND_API_KEY=
RESEND_FROM_EMAIL=CreatorForge <onboarding@resend.dev>

# LemonSqueezy billing (Pro subscriptions)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Cron protection for /api/cron/emails
CRON_SECRET=your-random-secret
